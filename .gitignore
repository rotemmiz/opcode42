# OS
.DS_Store

# Claude Code — personal/machine-specific overrides
.claude/settings.local.json

# Go build & test artifacts
*.test
*.out
*.prof
coverage.*
/bin/
/dist/

# Local env vars / secrets (never commit; .env.example documents the keys)
.env
.env.local
.envrc

# Local daemon runtime data
*.db
*.db-wal
*.db-shm

# Conformance run outputs (cassettes are committed; results are not)
/conformance/results/

# Derived codegen input (regenerated by `make gen`; the 3.1 reference is the contract).
# internal/api/gen's copy IS committed: it is embedded by conformance.go (plan 06 M10)
# so `go build`/`go test` work on a fresh checkout; it is deterministic and the
# `make gen` + `git diff` gate keeps it in sync. The sdk copy stays ephemeral.
/sdk/go/gen/openapi-3.0.derived.json
android/.kotlin/
.claude/worktrees/
