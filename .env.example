# Copy to .env (gitignored) and fill in, then `source .env` before running tests.
# Nothing auto-loads this file — Go tests read these via os.Getenv.

# Live provider proof for the agent engine (TestLive in internal/engine/enginetest).
# Any OpenAI-compatible endpoint works; examples below.
#
#   source .env && go test ./internal/engine/enginetest -run TestLive -v

# Groq (free tier):
OPCODE_TEST_BASE_URL=https://api.groq.com/openai/v1
OPCODE_TEST_MODEL=llama-3.3-70b-versatile
OPCODE_TEST_API_KEY=

# Cerebras: BASE_URL=https://api.cerebras.ai/v1            MODEL=llama-3.3-70b
# OpenRouter (free models): BASE_URL=https://openrouter.ai/api/v1  MODEL=<free model id>
# Local Ollama (no key):    BASE_URL=http://localhost:11434/v1     MODEL=llama3.2  (leave API_KEY empty)
