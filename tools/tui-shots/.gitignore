# Build artefacts and captured output — don't commit large binaries or PNGs.
# The harness scripts, tapes, fixture, fixture-session.json, and README are
# checked in; runtime output and daemon state are not.

# Compiled forge-tui binary
bin/

# Screenshot output (regenerated by ./capture.sh)
out/

# Opencode daemon + forge-tui KV state (generated at runtime)
state/

# The fixture source tree is tracked; fixture-empty is just a dir marker
fixture-empty/

# Stray test files
*.tape~
_*.gif
