{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(go:*)",
      "Bash(gofmt:*)",
      "Bash(goimports:*)",
      "Bash(golangci-lint:*)",
      "Bash(staticcheck:*)",
      "Bash(dlv:*)",
      "Bash(oapi-codegen:*)",
      "Bash(make:*)",
      "Bash(sqlite3:*)",
      "Bash(git status:*)",
