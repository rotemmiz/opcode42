<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Dark variant: windowBackground follows the platform dark background so the
         cold-start splash matches the dark scheme (no light flash). System-bar colors
         are transparent so enableEdgeToEdge() draws content behind them. -->
    <style name="Theme.Opcode42" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">?android:attr/colorBackground</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>
    </style>
</resources>