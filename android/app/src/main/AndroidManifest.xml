<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Make the on-device speech recognition service visible under package
         visibility filtering (targetSdk 30+), so isRecognitionAvailable() and
         SpeechRecognizer binding work for voice dictation. -->
    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>

    <!-- allowBackup is disabled deliberately: ServerConnectionManager stores server
         credentials in EncryptedSharedPreferences whose master key lives in the Android
         Keystore and is NOT included in Auto Backup / D2D transfer. A restored prefs file
         would be undecryptable, so EncryptedSharedPreferences.create() would throw and crash
         the app on first launch. Re-enable only alongside data-extraction rules that exclude
         the encrypted prefs + DataStore files. -->
    <application
        android:name=".Opcode42App"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.Opcode42">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Opcode42">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
